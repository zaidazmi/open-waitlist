# App
NEXT_PUBLIC_APP_NAME="Open Waitlist"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_WAITLIST_VERSION="v1"

# Backend / custom frontend
# Leave these empty when using the included frontend.
WAITLIST_API_URL=""
WAITLIST_SUCCESS_URL=""
WAITLIST_ALLOWED_ORIGINS=""
WAITLIST_RATE_LIMIT_MAX="10"
WAITLIST_RATE_LIMIT_WINDOW_MS="60000"
WAITLIST_EMAIL_RATE_LIMIT_MAX="3"
WAITLIST_EMAIL_RATE_LIMIT_WINDOW_MS="3600000"
WAITLIST_BOT_PROTECTION_ENABLED="true"
WAITLIST_HONEYPOT_FIELD="website"
WAITLIST_BOT_MIN_SUBMIT_MS="900"
WAITLIST_BOT_MAX_SUBMIT_MS="86400000"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"
SUPABASE_SECRET_KEY="your-service-role-or-secret-key"
# SUPABASE_SERVICE_ROLE_KEY is also supported if you prefer that name.

# Resend
RESEND_API_KEY="re_your_api_key"
WAITLIST_FROM_EMAIL="Open Waitlist <hello@example.com>"
WAITLIST_REPLY_TO="hello@example.com"
WAITLIST_EMAIL_FOOTER="Open Waitlist - An open-source verified referral waitlist"

# Optional analytics
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
